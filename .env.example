# Database (PostgreSQL)
# Para rodar local (sem Docker na API): use localhost
# Para rodar com docker-compose: o compose sobrescreve para apontar ao container
DATABASE_URL=postgresql://postgres:suasenha@localhost:5432/fashionai_local

# API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_use_openssl_rand_base64_64

# Environment
NODE_ENV=development
PORT=3002

# CORS Origins (separados por virgula)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
