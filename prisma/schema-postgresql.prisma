// Schema PostgreSQL otimizado para EconSciente
// Este é o novo schema - após testar, renomeie para schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Modelo de usuários
model User {
  id                  Int       @id @default(autoincrement())
  email               String    @unique
  password            String
  name                String
  biografia           String    @default("")
  dataNascimento      DateTime
  nivel               Int       @default(1)
  pontos              Int       @default(0)
  xp                  Int       @default(0)
  seguidores          Int       @default(0)
  seguindo            Int       @default(0)
  onboardingCompleted Boolean   @default(false)
  onboardingSteps     Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relacionamentos
  posts               Posts[]
  comentarios         Comentario[]
  likes               UserLike[]
  conquistas          ConquistaUsuario[]
  desafiosConcluidos  DesafiosConcluidos[]
  notificacoes        Notificacao[]
  sessoes             Session[]
  profilePic          ProfilePic?

  // Relacionamento de seguir
  seguindo_rel        Follow[]  @relation("UserFollowing")
  seguidores_rel      Follow[]  @relation("UserFollowers")

  @@index([email])
  @@index([createdAt])
  @@map("users")
}

// Modelo de posts
model Posts {
  id          Int          @id @default(autoincrement())
  userId      Int
  texto       String       @db.Text
  imagens     String[]
  curtidas    Int          @default(0)
  comentarios Int          @default(0)
  desafioId   Int?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relacionamentos
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  desafio     Desafios?    @relation(fields: [desafioId], references: [id], onDelete: SetNull)
  comentario  Comentario[]
  likes       UserLike[]

  @@index([userId])
  @@index([desafioId])
  @@index([createdAt])
  @@map("posts")
}

// Modelo de comentários
model Comentario {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    Int
  userName  String
  texto     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  post      Posts    @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
  @@index([createdAt])
  @@map("comentarios")
}

// Modelo de curtidas
model UserLike {
  id        Int      @id @default(autoincrement())
  userId    Int
  postId    Int
  createdAt DateTime @default(now())

  // Relacionamentos
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Posts    @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
  @@map("user_likes")
}

// Modelo de desafios
model Desafios {
  id        Int      @id @default(autoincrement())
  desafios  String   @db.Text
  valor     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  posts     Posts[]
  concluidos DesafiosConcluidos[]

  @@index([desafios])
  @@map("desafios")
}

// Modelo de desafios concluídos
model DesafiosConcluidos {
  id          Int      @id @default(autoincrement())
  desafioId   Int
  userId      Int
  completedAt DateTime @default(now())

  // Relacionamentos
  desafio     Desafios @relation(fields: [desafioId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, desafioId])
  @@index([desafioId])
  @@index([userId])
  @@map("desafios_concluidos")
}

// Modelo de conquistas
model Conquista {
  id               Int      @id @default(autoincrement())
  nome             String   @unique
  descricao        String   @db.Text
  icone            String
  tipo             String
  criterio         String   @db.Text
  pontosRecompensa Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relacionamentos
  usuarios         ConquistaUsuario[]

  @@index([tipo])
  @@index([nome])
  @@map("conquistas")
}

// Modelo de conquistas dos usuários
model ConquistaUsuario {
  id             Int      @id @default(autoincrement())
  conquistaId    Int
  userId         Int
  desbloqueadaEm DateTime @default(now())

  // Relacionamentos
  conquista      Conquista @relation(fields: [conquistaId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, conquistaId])
  @@index([userId])
  @@index([conquistaId])
  @@map("conquistas_usuarios")
}

// Modelo de relacionamento de seguir
model Follow {
  id          Int      @id @default(autoincrement())
  followerId  Int
  followingId Int
  createdAt   DateTime @default(now())

  // Relacionamentos
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

// Modelo de notificações
model Notificacao {
  id        Int      @id @default(autoincrement())
  userId    Int
  tipo      String
  mensagem  String   @db.Text
  lida      Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relacionamentos
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, lida])
  @@index([createdAt])
  @@map("notificacoes")
}

// Modelo de sessões
model Session {
  id           Int      @id @default(autoincrement())
  userId       Int
  sessionToken String   @unique
  isActive     Boolean  @default(true)
  lastActivity DateTime @default(now())
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?  @db.Text
  createdAt    DateTime @default(now())

  // Relacionamentos
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([sessionToken])
  @@map("sessions")
}

// Modelo de foto de perfil
model ProfilePic {
  id     Int     @id @default(autoincrement())
  userId Int     @unique
  name   String?
  url    String

  // Relacionamentos
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profile_pics")
}
