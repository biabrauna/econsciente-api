generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubmissaoStatus {
  PENDING
  PROCESSING
  SUCCESS
  ERROR
}

model User {
  id                  Int                  @id @default(autoincrement())
  email               String               @unique
  password            String
  name                String
  biografia           String               @default("")
  dataNascimento      DateTime
  nivel               Int                  @default(1)
  pontos              Int                  @default(0)
  xp                  Int                  @default(0)
  seguidores          Int                  @default(0)
  seguindo            Int                  @default(0)
  onboardingCompleted Boolean              @default(false)
  onboardingSteps     Json?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  onboardingSkippedAt DateTime?
  comentarios         Comentario[]
  conquistas          ConquistaUsuario[]
  desafiosSubmetidos  DesafiosSubmetidos[]
  seguindo_rel        Follow[]             @relation("UserFollowing")
  seguidores_rel      Follow[]             @relation("UserFollowers")
  notificacoes        Notificacao[]
  posts               Posts[]
  profilePic          ProfilePic?
  sessoes             Session[]
  likes               UserLike[]

  @@index([email])
  @@index([createdAt])
  @@map("users")
}

model Posts {
  id          Int          @id @default(autoincrement())
  userId      Int
  texto       String
  imagens     String[]
  curtidas    Int          @default(0)
  comentarios Int          @default(0)
  desafioId   Int?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  comentario  Comentario[]
  desafio     Desafios?    @relation(fields: [desafioId], references: [id])
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userLikes   UserLike[]

  @@index([userId])
  @@index([desafioId])
  @@index([createdAt])
  @@map("posts")
}

model Comentario {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    Int
  userName  String
  texto     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post      Posts    @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([userId])
  @@index([createdAt])
  @@map("comentarios")
}

model UserLike {
  id        Int      @id @default(autoincrement())
  userId    Int
  postId    Int
  createdAt DateTime @default(now())
  post      Posts    @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
  @@map("user_likes")
}

model Desafios {
  id         Int                  @id @default(autoincrement())
  desafios   String
  valor      Int
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  submetidos DesafiosSubmetidos[]
  posts      Posts[]

  @@index([desafios])
  @@map("desafios")
}

model DesafiosSubmetidos {
  id          Int             @id @default(autoincrement())
  userId      Int
  desafioId   Int
  imageUrl    String
  status      SubmissaoStatus @default(PENDING)
  submittedAt DateTime        @default(now())
  desafio     Desafios        @relation(fields: [desafioId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([desafioId])
  @@index([status])
  @@map("desafios_submetidos")
}

model Conquista {
  id               Int                @id @default(autoincrement())
  nome             String             @unique
  descricao        String
  icone            String
  tipo             String
  criterio         String
  pontosRecompensa Int
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  usuarios         ConquistaUsuario[]

  @@index([tipo])
  @@index([nome])
  @@map("conquistas")
}

model ConquistaUsuario {
  id             Int       @id @default(autoincrement())
  conquistaId    Int
  userId         Int
  desbloqueadaEm DateTime  @default(now())
  conquista      Conquista @relation(fields: [conquistaId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, conquistaId])
  @@index([userId])
  @@index([conquistaId])
  @@map("conquistas_usuarios")
}

model Follow {
  id          Int      @id @default(autoincrement())
  followerId  Int
  followingId Int
  createdAt   DateTime @default(now())
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

model Notificacao {
  id        Int      @id @default(autoincrement())
  userId    Int
  tipo      String
  mensagem  String
  lida      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, lida])
  @@index([createdAt])
  @@map("notificacoes")
}

model Session {
  id           Int      @id @default(autoincrement())
  userId       Int
  sessionToken String   @unique
  isActive     Boolean  @default(true)
  lastActivity DateTime @default(now())
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([sessionToken])
  @@map("sessions")
}

model ProfilePic {
  id     Int     @id @default(autoincrement())
  userId Int     @unique
  name   String?
  url    String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profile_pics")
}
