# Configuração PostgreSQL Local
# Copie este arquivo para .env e ajuste conforme necessário

# PostgreSQL Local (NOVO - substitui o MongoDB)
DATABASE_URL=postgresql://postgres:123456@localhost:5432/fashionai_local

# MongoDB (manter temporariamente apenas para migração)
MONGODB_URL=mongodb+srv://username:password@host/database?retryWrites=true&w=majority&appName=AppName

# URL temporária do PostgreSQL para o script de migração
POSTGRES_URL=postgresql://postgres:123456@localhost:5432/fashionai_local

# API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_use_openssl_rand_base64_64

# Environment
NODE_ENV=development
PORT=3002

# CORS Origins (separados por vírgula)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# IMPORTANTE: Após migração bem-sucedida:
# 1. Remova a linha MONGODB_URL
# 2. Remova a linha POSTGRES_URL (mantendo apenas DATABASE_URL)
# 3. Cancele o serviço MongoDB para economizar R$ 50/mês
